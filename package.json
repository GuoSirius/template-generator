{
  "name": "template-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@element-plus/icons-vue": "^2.3.1",
    "codemirror": "^6.0.1",
    "dexie": "^4.0.10",
    "element-plus": "^2.9.1",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.463.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@unocss/preset-attributify": "^0.65.2",
    "@unocss/preset-icons": "^0.65.2",
    "@unocss/preset-uno": "^0.65.2",
    "@unocss/reset": "^0.65.2",
    "@unocss/transformer-directives": "^0.65.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "unocss": "^0.65.2",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^6.0.5",
    "vitest": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
